#---------------------------------------------------------------------------
# gem5 SE-mode compatible make.def for NPB (static build)
#---------------------------------------------------------------------------

#---------------------------------------------------------------------------
# Fortran compiler
#---------------------------------------------------------------------------
F77 = gfortran
FLINK = gfortran

#---------------------------------------------------------------------------
# Fortran flags (STATIC is critical for gem5 SE mode)
#---------------------------------------------------------------------------
FFLAGS = -O3 -static -fno-second-underscore
FLINKFLAGS = -O3 -static

F_LIB =
F_INC =

#---------------------------------------------------------------------------
# C compiler
#---------------------------------------------------------------------------
CC = gcc
CLINK = gcc

#---------------------------------------------------------------------------
# C flags (STATIC is critical)
#---------------------------------------------------------------------------
CFLAGS = -O3 -static
CLINKFLAGS = -O3 -static

C_LIB =
C_INC =

#---------------------------------------------------------------------------
# Utility compiler
#---------------------------------------------------------------------------
UCC = gcc

#---------------------------------------------------------------------------
# Output directory
#---------------------------------------------------------------------------
BINDIR = ../bin

#---------------------------------------------------------------------------
# Random number generator
#---------------------------------------------------------------------------
RAND = randi8

#---------------------------------------------------------------------------
# Timer
#---------------------------------------------------------------------------
WTIME = wtime.c

#---------------------------------------------------------------------------
# Machine (leave unset for x86 Linux)
#---------------------------------------------------------------------------
# MACHINE = -DCRAY
# MACHINE = -DIBM


